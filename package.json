{
  "name": "leviathan-oracle",
  "version": "7.0.0",
  "description": "TypeScript rewrite of LeviathanOracle.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch . --ext ts,json --ignore dist --exec tsx index.ts",
    "build": "tsc && cp -r data/migrations dist/data/migrations",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "author": "ullamua",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "better-sqlite3": "^11.5.0",
    "bullmq": "^5.21.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "p-limit": "^5.0.0",
    "pg": "^8.13.1",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.11",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "nodemon": "^3.1.7",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
