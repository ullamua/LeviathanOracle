# Required
DISCORD_TOKEN=
BOT_ID=
ANIMESCHEDULE_TOKEN=

# Comma-separated list. The first one becomes the default owner.
OWNER_IDS=
ADMIN_IDS=

# Optional channel where /report submissions are posted
REPORT_CHANNEL_ID=

# Optional register dev-only commands in these guilds (comma-separated)
DEV_GUILD_IDS=

# Optional logging channels
GUILD_JOIN_LOGS_ID=
GUILD_LEAVE_LOGS_ID=
COMMAND_LOGS_CHANNEL_ID=
ERROR_LOGS_CHANNEL_ID=

# PostgreSQL leave blank to use SQLite (the default)
POSTGRES_ENABLED=false
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Or paste a single Postgres connection URL (takes priority over the fields above)
DATABASE_URL=

# Redis (optional), enables caching + persistent BullMQ scheduler.
REDIS_ENABLED=false
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=

# Mongo (optional), currently unused but kept for future expansion
MONGO_URL=

# Logging
LOG_LEVEL=info
LOG_FILE_DIR=logs
